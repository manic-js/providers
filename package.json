{
  "name": "@manicjs/providers",
  "version": "1.0.2",
  "description": "Deployment providers for Manic framework - Vercel, Cloudflare, Netlify",
  "keywords": [
    "adapter",
    "cloudflare",
    "deploy",
    "manic",
    "netlify",
    "vercel"
  ],
  "homepage": "https://github.com/manic-js/providers#readme",
  "bugs": {
    "url": "https://github.com/manic-js/providers/issues"
  },
  "license": "GPL-3.0",
  "author": "Rahuletto",
  "repository": {
    "type": "git",
    "url": "https://github.com/manic-js/providers"
  },
  "files": [
    "src/**/*",
    "README.md"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./vercel": {
      "types": "./src/vercel/index.ts",
      "import": "./src/vercel/index.ts"
    },
    "./cloudflare": {
      "types": "./src/cloudflare/index.ts",
      "import": "./src/cloudflare/index.ts"
    },
    "./netlify": {
      "types": "./src/netlify/index.ts",
      "import": "./src/netlify/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@manicjs/tui": "1.0.1"
  },
  "devDependencies": {
    "@shikijs/transformers": "^4.0.2",
    "@types/bun": "1.3.13",
    "@types/mdx": "^2.0.13",
    "fumadocs-docgen": "^3.0.10",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {},
  "simple-git-hooks": {
    "pre-commit": "bunx --bun oxlint . && bunx --bun oxfmt --check --config .oxfmt.json ."
  }
}
