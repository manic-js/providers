{
  "name": "@manicjs/providers",
  "version": "0.8.1",
  "description": "Deployment providers for Manic framework - Vercel, Cloudflare, Netlify",
  "keywords": [
    "adapter",
    "cloudflare",
    "deploy",
    "manic",
    "netlify",
    "vercel"
  ],
  "homepage": "https://github.com/Rahuletto/manic#readme",
  "bugs": {
    "url": "https://github.com/Rahuletto/manic/issues"
  },
  "license": "GPL-3.0",
  "author": "Rahuletto",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rahuletto/manic"
  },
  "files": [
    "src/**/*",
    "README.md"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./vercel": {
      "types": "./src/vercel/index.ts",
      "import": "./src/vercel/index.ts"
    },
    "./cloudflare": {
      "types": "./src/cloudflare/index.ts",
      "import": "./src/cloudflare/index.ts"
    },
    "./netlify": {
      "types": "./src/netlify/index.ts",
      "import": "./src/netlify/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "colorette": "^2.0.20"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "manicjs": ">=0.7.2"
  }
}
